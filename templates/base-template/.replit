modules = ["nodejs-24", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
SES_SENDER_EMAIL = "no-reply@lyzr.app"
SMTP_HOST = "email-smtp.us-east-1.amazonaws.com"
SMTP_PORT = "587"
SMTP_USERNAME = "AKIA4AQ3T5UFC5NWXWBR"
SMTP_PASSWORD = "BK41bgtU5kMZyuoJH7iSp5uAz0D1BeVBK6+i/8ym+T+U"

[nix]
channel = "stable-25_05"
